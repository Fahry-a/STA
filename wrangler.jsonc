{
  "$schema": "node_modules/wrangler/config-schema.json",
  "account_id": "2ec2e8ff2ebc31a2db2cb400d5b08a4e",
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "deeplx-analytics"
    }
  ],
  "compatibility_date": "2025-07-19",
  "kv_namespaces": [
    {
      "binding": "CACHE_KV",
      "id": "9b17a4f5a9074c13a7d3796a9170b74d"
    },
    {
      "binding": "RATE_LIMIT_KV",
      "id": "78b21a8a40a54d888582ef576ef9354f"
    }
  ],
  "main": "src/index.ts",
  "name": "deeplx",
  "observability": {
    "enabled": true,
